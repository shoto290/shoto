{
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"permissions": {
		"deny": [
			"Bash(curl:*)",
			"Bash(git push --force*)",
			"Bash(git push -f*)",
			"Bash(git reset --hard*)",
			"Bash(rm -rf *)",
			"Bash(prisma migrate reset*)",
			"Read(./.env)",
			"Read(./.env.*)",
			"Read(./secrets/**)",
			"Write(./.env*)",
			"Write(./secrets/**)",
			"Bash(bun run dev)"
		]
	},
	"hooks": {
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/remind-version-bump.sh"
					}
				]
			}
		]
	}
}